{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=MemoireNomadeDB;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "JwtSettings": {
    "SecretKey": "YOUR_SECRET_KEY_HERE_MINIMUM_32_CHARACTERS",
    "Issuer": "MemoireNomade.API",
    "Audience": "MemoireNomade.Client",
    "ExpirationMinutes": 60
  },

  "RefreshTokenSettings": {
    "ExpirationDays": 7
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },

  "AllowedHosts": "*"
}
